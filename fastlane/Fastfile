# Fastlane config for BlinkBreak — iOS TestFlight CD.
#
# Pattern based on: todaywhat/TodayWhat-iOS, britt/climbertimer, evanjt/traintime.
#
# Locally: run `fastlane seed_certs` once after setting up match.
# CI:     runs `fastlane beta` via GH Actions on push to main.
#
# Required environment variables (populated by Doppler in CI):
#   MATCH_PASSWORD             - AES key for the certs repo
#   MATCH_KEYCHAIN_PASSWORD    - password for CI's ephemeral keychain
#   ASC_KEY_ID                 - App Store Connect API key ID
#   ASC_ISSUER_ID              - App Store Connect issuer ID
#   ASC_API_KEY_CONTENT        - contents of the AuthKey_*.p8 file (raw or base64)
#   ASC_API_KEY_IS_BASE64      - "true" if ASC_API_KEY_CONTENT is base64-encoded
#
# Locally: set the same env vars (or pass them via `doppler run --`).

default_platform(:ios)

APP_IDENTIFIER = "com.tytaniumdev.BlinkBreak".freeze
XCODEPROJ      = "BlinkBreak.xcodeproj".freeze
SCHEME         = "BlinkBreak".freeze

# Shared helper: build an App Store Connect API key object that match, pilot,
# and build_app all accept. Called from every lane.
def asc_api_key
  app_store_connect_api_key(
    key_id:                ENV.fetch("ASC_KEY_ID"),
    issuer_id:             ENV.fetch("ASC_ISSUER_ID"),
    key_content:           ENV.fetch("ASC_API_KEY_CONTENT"),
    is_key_content_base64: ENV["ASC_API_KEY_IS_BASE64"] == "true",
    in_house:              false
  )
end

platform :ios do

  desc "Seed the match certs repo with Distribution cert + App Store profile (run once locally)"
  lane :seed_certs do
    match(
      api_key: asc_api_key,
      git_url: "git@github.com:TytaniumDev/BlinkBreak-certificates.git",
      storage_mode: "git",
      type: "appstore",
      app_identifier: [APP_IDENTIFIER],
      readonly: false,
      force_for_new_devices: false
    )
  end

  desc "Install signing assets from match (read-only)"
  lane :sync_certs do
    if is_ci
      create_keychain(
        name: "blinkbreak.keychain",
        password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD"),
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
    end

    match(
      api_key: asc_api_key,
      git_url: "git@github.com:TytaniumDev/BlinkBreak-certificates.git",
      storage_mode: "git",
      type: "appstore",
      app_identifier: [APP_IDENTIFIER],
      readonly: true,
      keychain_name: is_ci ? "blinkbreak.keychain" : nil,
      keychain_password: is_ci ? ENV.fetch("MATCH_KEYCHAIN_PASSWORD") : nil
    )
  end

  desc "Build and upload a new TestFlight build"
  lane :beta do
    # Regenerate the .xcodeproj from project.yml so xcodegen stays the source of truth.
    sh("cd .. && xcodegen generate")

    sync_certs

    # Flip the target from xcodegen's default "Automatic" signing to "Manual"
    # with the match-provided Distribution profile. This is the step that
    # prevents xcodebuild from trying to fetch a Development profile during
    # archive.
    update_code_signing_settings(
      path: XCODEPROJ,
      use_automatic_signing: false,
      targets: ["BlinkBreak"],
      team_id: "F2HXQGU2CC",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{APP_IDENTIFIER}",
      bundle_identifier: APP_IDENTIFIER
    )

    api_key = asc_api_key

    # Auto-bump CFBundleVersion to (latest TestFlight build number) + 1.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    )
    new_build_number = latest.to_i + 1
    UI.message("Next build number: #{new_build_number}")

    increment_build_number(
      xcodeproj: XCODEPROJ,
      build_number: new_build_number
    )

    # Archive + export with explicit provisioning profile mapping. By naming
    # match's profile in export_options, xcodebuild stays on classic signing
    # and never touches Xcode 16's cloud-signing path (which would need the
    # Admin API key role — we only have App Manager).
    build_app(
      project: XCODEPROJ,
      scheme:  SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      },
      xcargs: 'OTHER_CODE_SIGN_FLAGS="--timestamp=none"',
      output_directory: "build",
      output_name: "BlinkBreak.ipa",
      clean: false,
      silent: false
    )

    # Upload dSYMs to Sentry so production crashes symbolicate against this
    # build. The plugin reads DSYM_OUTPUT_PATH from build_app's lane context,
    # so no path plumbing needed. SENTRY_AUTH_TOKEN comes from Doppler.
    sentry_debug_files_upload(
      auth_token: ENV.fetch("SENTRY_AUTH_TOKEN"),
      org_slug: "tytaniumdev",
      project_slug: "blinkbreak"
    )

    # Create the matching release in Sentry. The release name must match what
    # SentryBootstrap.swift constructs at runtime — "<bundle>@<version>+<build>".
    sentry_create_release(
      auth_token: ENV.fetch("SENTRY_AUTH_TOKEN"),
      org_slug: "tytaniumdev",
      project_slug: "blinkbreak",
      version: "#{APP_IDENTIFIER}@#{get_version_number(xcodeproj: XCODEPROJ, target: 'BlinkBreak')}+#{new_build_number}",
      finalize: true
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
